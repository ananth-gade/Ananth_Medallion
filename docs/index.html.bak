<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RS Medallion — Developer Guide</title>
    <style>
        /* ===== Reset & Base ===== */
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        :root {
            --bg: #0d1117; --surface: #161b22; --surface2: #1c2129;
            --border: #30363d; --text: #e6edf3; --text-muted: #8b949e;
            --accent: #58a6ff; --accent-dim: #1f6feb; --green: #3fb950;
            --orange: #d29922; --red: #f85149; --purple: #bc8cff;
            --gold: #f0c75e; --silver: #8b949e; --bronze: #da8a67;
            --font: 'Segoe UI', -apple-system, BlinkMacSystemFont, sans-serif;
            --mono: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;
            --radius: 8px;
        }
        html { scroll-behavior: smooth; scroll-padding-top: 80px; }
        body { font-family: var(--font); background: var(--bg); color: var(--text); line-height: 1.7; }
        a { color: var(--accent); text-decoration: none; transition: color .2s; }
        a:hover { color: #79c0ff; text-decoration: underline; }
        code, pre { font-family: var(--mono); font-size: .88em; }
        code { background: var(--surface2); padding: 2px 6px; border-radius: 4px; color: var(--accent); }
        pre { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 16px 20px; overflow-x: auto; line-height: 1.55; }
        pre code { background: none; padding: 0; color: var(--text); font-size: .85em; }

        /* ===== Layout ===== */
        .page { display: flex; min-height: 100vh; }
        .sidebar {
            position: fixed; top: 0; left: 0; width: 280px; height: 100vh;
            background: var(--surface); border-right: 1px solid var(--border);
            overflow-y: auto; padding: 20px 0; z-index: 100;
        }
        .sidebar::-webkit-scrollbar { width: 4px; }
        .sidebar::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }
        .main { margin-left: 280px; flex: 1; max-width: 960px; padding: 40px 48px 80px; }

        /* Sidebar nav */
        .sidebar .logo { padding: 0 20px 16px; border-bottom: 1px solid var(--border); margin-bottom: 12px; }
        .sidebar .logo h2 { font-size: 1.15em; color: var(--gold); letter-spacing: .5px; }
        .sidebar .logo p { font-size: .75em; color: var(--text-muted); margin-top: 2px; }
        .nav-group { padding: 4px 0; }
        .nav-group-title {
            display: block; padding: 6px 20px; font-size: .7em; font-weight: 700;
            text-transform: uppercase; letter-spacing: 1.2px; color: var(--text-muted);
        }
        .nav-link {
            display: block; padding: 5px 20px 5px 28px; font-size: .85em;
            color: var(--text-muted); transition: all .15s; border-left: 2px solid transparent;
        }
        .nav-link:hover { color: var(--text); background: rgba(88,166,255,.06); text-decoration: none; }
        .nav-link.active { color: var(--accent); border-left-color: var(--accent); background: rgba(88,166,255,.08); }
        .nav-link .badge {
            display: inline-block; font-size: .65em; padding: 1px 6px; border-radius: 10px;
            margin-left: 6px; vertical-align: middle;
        }
        .badge-bronze { background: rgba(218,138,103,.18); color: var(--bronze); }
        .badge-silver { background: rgba(139,148,158,.18); color: var(--silver); }
        .badge-gold { background: rgba(240,199,94,.18); color: var(--gold); }
        .badge-audit { background: rgba(188,140,255,.18); color: var(--purple); }
        .badge-macro { background: rgba(63,185,80,.18); color: var(--green); }

        /* Content */
        h1 { font-size: 2em; font-weight: 800; margin-bottom: 8px; color: var(--text); }
        h1 .version { font-size: .4em; color: var(--text-muted); font-weight: 400; vertical-align: middle; }
        h2 { font-size: 1.55em; font-weight: 700; margin: 48px 0 16px; padding-bottom: 8px; border-bottom: 1px solid var(--border); }
        h3 { font-size: 1.2em; font-weight: 600; margin: 32px 0 12px; color: var(--accent); }
        h4 { font-size: 1em; font-weight: 600; margin: 20px 0 8px; color: var(--text); }
        p { margin-bottom: 12px; }
        ul, ol { margin: 8px 0 16px 24px; }
        li { margin-bottom: 4px; }
        hr { border: none; border-top: 1px solid var(--border); margin: 32px 0; }

        /* Cards */
        .card {
            background: var(--surface); border: 1px solid var(--border);
            border-radius: var(--radius); padding: 20px 24px; margin: 16px 0;
        }
        .card-header { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
        .card-header .icon { font-size: 1.3em; }
        .card-header h4 { margin: 0; }

        /* Diagrams / Flow */
        .flow { display: flex; align-items: center; flex-wrap: wrap; gap: 8px; margin: 20px 0; }
        .flow-node {
            padding: 10px 18px; border-radius: var(--radius); font-weight: 600; font-size: .85em;
            border: 1px solid; text-align: center; min-width: 100px;
        }
        .flow-arrow { color: var(--text-muted); font-size: 1.3em; }
        .node-source { background: rgba(139,148,158,.1); border-color: var(--silver); color: var(--silver); }
        .node-bronze { background: rgba(218,138,103,.1); border-color: var(--bronze); color: var(--bronze); }
        .node-silver { background: rgba(139,148,158,.15); border-color: #adbac7; color: #adbac7; }
        .node-gold { background: rgba(240,199,94,.1); border-color: var(--gold); color: var(--gold); }
        .node-audit { background: rgba(188,140,255,.1); border-color: var(--purple); color: var(--purple); }

        /* Tables */
        .tbl { width: 100%; border-collapse: collapse; margin: 16px 0; font-size: .88em; }
        .tbl th { background: var(--surface2); font-weight: 600; text-align: left; padding: 10px 14px; border-bottom: 2px solid var(--border); }
        .tbl td { padding: 9px 14px; border-bottom: 1px solid var(--border); vertical-align: top; }
        .tbl tr:hover td { background: rgba(88,166,255,.04); }
        .tbl .mono { font-family: var(--mono); font-size: .9em; }

        /* Callouts */
        .callout {
            padding: 14px 18px; border-radius: var(--radius); margin: 16px 0;
            border-left: 4px solid; font-size: .92em;
        }
        .callout-info { background: rgba(88,166,255,.08); border-color: var(--accent); }
        .callout-warn { background: rgba(210,153,34,.08); border-color: var(--orange); }
        .callout-success { background: rgba(63,185,80,.08); border-color: var(--green); }
        .callout-tip { background: rgba(188,140,255,.08); border-color: var(--purple); }
        .callout strong { display: block; margin-bottom: 4px; }

        /* Tabs */
        .tabs { display: flex; gap: 0; border-bottom: 1px solid var(--border); margin-top: 16px; }
        .tab-btn {
            padding: 8px 18px; font-size: .85em; cursor: pointer; border: none; background: none;
            color: var(--text-muted); font-weight: 500; border-bottom: 2px solid transparent; transition: all .2s;
        }
        .tab-btn:hover { color: var(--text); }
        .tab-btn.active { color: var(--accent); border-bottom-color: var(--accent); }
        .tab-content { display: none; padding: 16px 0; }
        .tab-content.active { display: block; }

        /* Layer badges inline */
        .layer-tag {
            display: inline-block; padding: 2px 10px; border-radius: 12px;
            font-size: .72em; font-weight: 600; letter-spacing: .5px; vertical-align: middle;
        }
        .tag-bronze { background: rgba(218,138,103,.18); color: var(--bronze); }
        .tag-silver { background: rgba(139,148,158,.22); color: #adbac7; }
        .tag-gold { background: rgba(240,199,94,.18); color: var(--gold); }
        .tag-audit { background: rgba(188,140,255,.18); color: var(--purple); }

        /* File tree */
        .file-tree { font-family: var(--mono); font-size: .82em; line-height: 1.9; }
        .file-tree .dir { color: var(--accent); }
        .file-tree .file { color: var(--text-muted); }

        /* Responsive */
        @media (max-width: 900px) {
            .sidebar { display: none; }
            .main { margin-left: 0; padding: 24px; }
        }

        /* Architecture diagram */
        .arch-diagram {
            display: grid; grid-template-columns: 1fr; gap: 12px; margin: 24px 0;
        }
        .arch-layer {
            border: 1px solid var(--border); border-radius: var(--radius);
            padding: 16px 20px; position: relative; overflow: hidden;
        }
        .arch-layer::before {
            content: ''; position: absolute; top: 0; left: 0; bottom: 0; width: 4px;
        }
        .arch-layer.l-source::before { background: var(--silver); }
        .arch-layer.l-bronze::before { background: var(--bronze); }
        .arch-layer.l-silver::before { background: #adbac7; }
        .arch-layer.l-gold::before { background: var(--gold); }
        .arch-layer.l-audit::before { background: var(--purple); }
        .arch-layer h4 { margin: 0 0 6px; }
        .arch-layer .meta { font-size: .8em; color: var(--text-muted); }

        .hero-sub { color: var(--text-muted); font-size: 1.05em; margin-bottom: 32px; }
        .highlight { color: var(--gold); }

        /* Steps */
        .step { display: flex; gap: 16px; margin: 12px 0; }
        .step-num {
            flex-shrink: 0; width: 32px; height: 32px; border-radius: 50%;
            background: var(--accent-dim); color: #fff; display: flex;
            align-items: center; justify-content: center; font-weight: 700; font-size: .85em;
        }
        .step-body { flex: 1; padding-top: 4px; }

        /* Copy button */
        .code-block { position: relative; }
        .copy-btn {
            position: absolute; top: 8px; right: 8px; background: var(--surface2);
            border: 1px solid var(--border); color: var(--text-muted); padding: 4px 10px;
            border-radius: 4px; font-size: .72em; cursor: pointer; transition: all .2s;
        }
        .copy-btn:hover { color: var(--text); border-color: var(--accent); }

        footer { margin-top: 64px; padding-top: 24px; border-top: 1px solid var(--border); color: var(--text-muted); font-size: .82em; text-align: center; }
    </style>
</head>
<body>

